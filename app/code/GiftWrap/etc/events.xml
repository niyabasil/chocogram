<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="payment_cart_collect_items_and_amounts">
        <observer name="Amasty_GiftWrap::AddPaymentGiftWrapItem" instance="Amasty\GiftWrap\Observer\AddPaymentGiftWrapItem" />
    </event>
    <event name="sales_model_service_quote_submit_before">
        <observer name="Amasty_GiftWrap::SubmitQuoteBefore" instance="Amasty\GiftWrap\Observer\SubmitQuoteBefore" />
    </event>
    <event name="sales_quote_merge_after">
        <observer name="Amasty_GiftWrap::MergeQuoteAfter" instance="Amasty\GiftWrap\Observer\MergeQuoteAfter" />
    </event>
    <!-- add wraps to addresses on multishipping -->
    <event name="checkout_controller_multishipping_shipping_post">
        <observer name="Amasty_GiftWrap::AddWrapsOnMultishipping" instance="Amasty\GiftWrap\Observer\Multishipping\ShippingPost" />
    </event>
    <!-- move wraps from quote address entity to order entity -->
    <event name="checkout_type_multishipping_create_orders_single">
        <observer name="Amasty_GiftWrap::CreateOrderSingle" instance="Amasty\GiftWrap\Observer\Multishipping\CreateOrder" />
    </event>
    <event name="sales_quote_remove_item">
        <observer instance="Amasty\GiftWrap\Observer\SalesQuoteRemoveItem" name="Amasty_GiftWrap::RemoveWrap"/>
    </event>

    <!-- GiftCard Compatibility -->
    <event name="amgcard_allowed_subtotal_calculated">
        <observer name="Amasty_GiftWrap::ModifyGiftCardAllowedSubtotal" instance="Amasty\GiftWrap\Observer\ModifyGiftCardAllowedSubtotal" />
    </event>
</config>
