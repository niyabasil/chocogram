    </route>
    <route url="/V1/amasty_giftWrap/message_card/:entityId" method="DELETE">
        <service class="Amasty\GiftWrap\Api\MessageCardRepositoryInterface" method="deleteById"/>
        <resources>
            <resource ref="Amasty_GiftWrap::message_card" />
        </resources>
    </route>
    <route url="/V1/amasty_giftWrap/message_card" method="GET">
        <service class="Amasty\GiftWrap\Api\MessageCardRepositoryInterface" method="getById"/>
